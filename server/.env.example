# Server environment variables (copy to .env and fill in real values)

# Port the Express API listens on
PORT=5000

# URL of the Next.js client (used for CORS)
CLIENT_URL=http://localhost:3000

# MySQL connection string used by Prisma
DATABASE_URL="mysql://root:password@localhost:3306/uninest"

# Secret used to sign JWT access tokens (use a long random string)
JWT_SECRET="change-me-to-a-long-random-string"

# Google OAuth client ID (leave empty to disable Google login)
GOOGLE_CLIENT_ID=""

# SMTP settings (leave SMTP_HOST empty to log emails to the console in dev)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="UNI-NEST <no-reply@uninest.com>"
